-- Helper: serialize current animation data to Lua table string
local function serializeAnimData()
    local lines = {}
    table.insert(lines, "local ANIM_DATA = {")
    table.insert(lines, "  speed="..ST.speed..",")
    table.insert(lines, "  fps=60,")
    table.insert(lines, "  total="..ST.total..",")
    table.insert(lines, "  loop="..(ST.exportLoop and "true" or "false")..",")
    table.insert(lines, "  tracks={")
    
    for id,tr in pairs(ST.tracks) do
        local kfs = ST.kfs[id]
        if not kfs or not next(kfs) then continue end
        
        -- For NPC: use relative name from model root
        -- For Player: use Motor6D name
        local tname = tr.name
        local ttype = tr.type
        
        table.insert(lines, '    {name="'..tname..'",type="'..ttype..'",kf={')
        
        local frames={}
        for f in pairs(kfs) do table.insert(frames,f) end
        table.sort(frames)
        
        for _,f in ipairs(frames) do
            table.insert(lines, "      ["..f.."]={")
            for pn,pi in pairs(kfs[f]) do
                local vStr
                if pi.t == "CFrame" then
                    local comps = {pi.v:GetComponents()}
                    local parts = {}
                    for _,x in ipairs(comps) do table.insert(parts,string.format("%.4f",x)) end
                    vStr = "CFrame.new("..table.concat(parts,",")..")"
                elseif pi.t == "Vector3" then
                    vStr = string.format("Vector3.new(%.4f,%.4f,%.4f)",pi.v.X,pi.v.Y,pi.v.Z)
                elseif pi.t == "Color3" then
                    vStr = string.format("Color3.new(%.4f,%.4f,%.4f)",pi.v.R,pi.v.G,pi.v.B)
                elseif pi.t == "Number" then
                    vStr = string.format("%.4f",pi.v)
                elseif pi.t == "UDim2" then
                    vStr = string.format("UDim2.new(%.4f,%d,%.4f,%d)",pi.v.X.Scale,pi.v.X.Offset,pi.v.Y.Scale,pi.v.Y.Offset)
                end
                if vStr then
                    local extra = ""
                    if pi.bh then
                        extra = string.format(",bh={%.3f,%.3f,%.3f,%.3f}",pi.bh[1],pi.bh[2],pi.bh[3],pi.bh[4])
                    end
                    table.insert(lines, '        ["'..pn..'"]=')
                    table.insert(lines, '          {v='..vStr..',t="'..pi.t..'",es="'..(pi.es or "Linear")..'",ed="'..(pi.ed or "InOut")..'"'..extra..'},')
                end
            end
            table.insert(lines, "      },")
        end
        table.insert(lines, "    }},")
    end
    table.insert(lines, "  }")
    table.insert(lines, "}")
    return table.concat(lines, "\n")
end

-- Engine code (shared by all export types)
local ENGINE_CODE = [==[
-- ❄️ Animation Engine
local RS = game:GetService("RunService")
local function bO(x) local n=7.5625;local d=2.75;if x<1/d then return n*x*x elseif x<2/d then x=x-1.5/d;return n*x*x+0.75 elseif x<2.5/d then x=x-2.25/d;return n*x*x+0.9375 else x=x-2.625/d;return n*x*x+0.984375 end end
local function eI(x,s) if s=="Linear" then return x elseif s=="Quad" then return x*x elseif s=="Cubic" then return x^3 elseif s=="Quart" then return x^4 elseif s=="Quint" then return x^5 elseif s=="Sine" then return 1-math.cos(x*math.pi/2) elseif s=="Exponential" then return x==0 and 0 or 2^(10*(x-1)) elseif s=="Circular" then return 1-math.sqrt(math.max(0,1-x*x)) elseif s=="Elastic" then if x==0 or x==1 then return x end;return -(2^(10*(x-1)))*math.sin((x-1.075)*2*math.pi/0.3) elseif s=="Back" then return x*x*((1.70158+1)*x-1.70158) elseif s=="Bounce" then return 1-bO(1-x) end;return x end
local function EE(t,s,d) if d=="In" then return eI(t,s) elseif d=="Out" then return 1-eI(1-t,s) else if t<0.5 then return eI(t*2,s)/2 else return 1-eI((1-t)*2,s)/2 end end end
local function BezEval(t,h1x,h1y,h2x,h2y) local function cb(t2,p0,p1,p2,p3) local u=1-t2;return u*u*u*p0+3*u*u*t2*p1+3*u*t2*t2*p2+t2*t2*t2*p3 end;local lo,hi=0,1;for _=1,20 do local m=(lo+hi)/2;if cb(m,0,h1x,h2x,1)<t then lo=m else hi=m end end;return cb((lo+hi)/2,0,h1y,h2y,1) end
local function lerp(a,b,t) return a+(b-a)*t end
local function IV(v1,v2,a,vt) if vt=="CFrame" then return v1:Lerp(v2,a) elseif vt=="Vector3" then return v1:Lerp(v2,a) elseif vt=="Color3" then return Color3.new(lerp(v1.R,v2.R,a),lerp(v1.G,v2.G,a),lerp(v1.B,v2.B,a)) elseif vt=="Number" then return lerp(v1,v2,a) elseif vt=="UDim2" then return UDim2.new(lerp(v1.X.Scale,v2.X.Scale,a),lerp(v1.X.Offset,v2.X.Offset,a),lerp(v1.Y.Scale,v2.Y.Scale,a),lerp(v1.Y.Offset,v2.Y.Offset,a)) end;return a<0.5 and v1 or v2 end

local function playAnimation(data, findTarget)
    local resolved = {}
    for _,track in ipairs(data.tracks) do
        local inst = findTarget(track.name, track.type)
        if inst then
            table.insert(resolved, {inst=inst, kf=track.kf})
        else
            warn("❄️ SNA: Could not find '"..track.name.."' ("..track.type..")")
        end
    end
    if #resolved == 0 then warn("❄️ SNA: No tracks resolved!") return end
    
    local cf, acc = 0, 0
    local conn
    conn = RS.Heartbeat:Connect(function(dt)
        acc = acc + dt * data.speed
        local ft = 1/data.fps
        while acc >= ft do
            acc = acc - ft
            cf = cf + 1
            if cf > data.total then
                if data.loop then cf = 0
                else conn:Disconnect(); return end
            end
        end
        for _,t in pairs(resolved) do
            if not t.inst or not t.inst.Parent then continue end
            local fs = {}
            for f in pairs(t.kf) do table.insert(fs, f) end
            table.sort(fs)
            if #fs == 0 then continue end
            local pf,nf,pd,nd
            for _,f in ipairs(fs) do
                if f <= cf then pf=f; pd=t.kf[f] end
                if f > cf and not nf then nf=f; nd=t.kf[f] end
            end
            if pf and nf and pd and nd then
                local tt = (cf-pf)/(nf-pf)
                for pn,pi in pairs(pd) do
                    if nd[pn] then
                        local a
                        if pi.bh then
                            a = BezEval(tt,pi.bh[1],pi.bh[2],pi.bh[3],pi.bh[4])
                        else
                            a = EE(tt,pi.es or "Linear",pi.ed or "InOut")
                        end
                        pcall(function() t.inst[pn] = IV(pi.v,nd[pn].v,a,pi.t) end)
                    end
                end
            elseif pf and pd then
                for pn,pi in pairs(pd) do
                    pcall(function() t.inst[pn] = pi.v end)
                end
            end
        end
    end)
    return conn
end
