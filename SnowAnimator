local SAVE_KEY = "SNA_v8_SaveData"
local function SaveToStorage(data)
    local json = HttpService:JSONEncode(data)
    -- Multiple methods for different executors
    pcall(function()
        if writefile then
            writefile("SNA_Saves.json", json)
        end
    end)
    pcall(function()
        if setclipboard then
            -- Fallback: also store in a StringValue
        end
    end)
    -- Store in ReplicatedStorage as backup
    pcall(function()
        local sv = ReplicatedStorage:FindFirstChild("SNA_PersistentSaves")
        if not sv then
            sv = Instance.new("StringValue")
            sv.Name = "SNA_PersistentSaves"
            sv.Parent = ReplicatedStorage
        end
        sv.Value = json
    end)
end

local function LoadFromStorage()
    -- Try file first
    local data = nil
    pcall(function()
        if readfile and isfile and isfile("SNA_Saves.json") then
            data = HttpService:JSONDecode(readfile("SNA_Saves.json"))
        end
    end)
    if data then return data end
    -- Try ReplicatedStorage backup
    pcall(function()
        local sv = ReplicatedStorage:FindFirstChild("SNA_PersistentSaves")
        if sv and sv.Value ~= "" then
            data = HttpService:JSONDecode(sv.Value)
        end
    end)
    return data or {saves={}, slots={}}
end

