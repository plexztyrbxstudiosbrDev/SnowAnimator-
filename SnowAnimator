function addKeyframe()
    if not ST.target then notify("Use 🎯 first!",C.YEL) return end
    pushUndo();local f=ST.frame;local ct=0
    for id,tr in pairs(ST.tracks) do if tr.vis and not tr.lock then
        if not ST.kfs[id] then ST.kfs[id]={} end;local kd={}
        for _,p in ipairs(tr.props) do pcall(function()
            kd[p.n]={v=tr.inst[p.n],t=p.t,es=ST.easing,ed=ST.easeDir}
            if ST.curveMode then kd[p.n].bh={ST.bezH.h1x,ST.bezH.h1y,ST.bezH.h2x,ST.bezH.h2y} end
        end) end;ST.kfs[id][f]=kd;ct=ct+1
    end end;notify("KEY @"..f.." ("..ct..")",C.GRN);rebuildTimeline()
end

function loadTarget(target)
    ST.target=target;ST.tracks={};ST.kfs={};ST.originals={}
    local function addTrack(inst,tp) local id=inst:GetFullName();if ST.tracks[id] then return end;local props=getProps(inst);if #props==0 then return end;ST.tracks[id]={inst=inst,name=inst.Name,type=tp,props=props,vis=true,lock=false};ST.kfs[id]={};ST.originals[id]={};for _,p in ipairs(props) do pcall(function() ST.originals[id][p.n]=inst[p.n] end) end end
    if target:IsA("Model") then
        for _,d in pairs(target:GetDescendants()) do if d:IsA("Motor6D") then addTrack(d,"Motor6D") end end
        for _,d in pairs(target:GetDescendants()) do if d:IsA("BasePart") then addTrack(d,"BasePart") end end
    elseif target:IsA("BasePart") then addTrack(target,"BasePart")
    elseif target:IsA("GuiObject") then addTrack(target,"GuiObject");for _,d in pairs(target:GetDescendants()) do if d:IsA("GuiObject") then addTrack(d,"GuiObject") end end
    else for _,d in pairs(target:GetDescendants()) do if d:IsA("Motor6D") then addTrack(d,"Motor6D") elseif d:IsA("BasePart") then addTrack(d,"BasePart") elseif d:IsA("GuiObject") then addTrack(d,"GuiObject") end end end
    local ct=0;for _ in pairs(ST.tracks) do ct=ct+1 end
    notify("✅ "..target.Name.." ("..ct..")",C.GRN,3)
    rebuildTracks();rebuildTimeline();startGizmoMonitor()
end

