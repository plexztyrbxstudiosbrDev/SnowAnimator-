function rebuildCurveEditor()
    for _,c2 in pairs(curveCanvas:GetChildren()) do if c2:IsA("Frame") or c2:IsA("TextButton") then c2:Destroy() end end
    local w=curveCanvas.AbsoluteSize.X;local h=curveCanvas.AbsoluteSize.Y
    if w<10 then w=280 end;if h<10 then h=160 end
    for g=0,4 do
        new("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(g/4,0,0,0),BackgroundColor3=C.SEP,BackgroundTransparency=0.7,ZIndex=83,Parent=curveCanvas})
        new("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,g/4,0),BackgroundColor3=C.SEP,BackgroundTransparency=0.7,ZIndex=83,Parent=curveCanvas})
    end
    local segs=35
    for i=0,segs-1 do
        local t1=i/segs;local t2=(i+1)/segs
        local y1=1-BezEval(t1,ST.bezH.h1x,ST.bezH.h1y,ST.bezH.h2x,ST.bezH.h2y)
        local y2=1-BezEval(t2,ST.bezH.h1x,ST.bezH.h1y,ST.bezH.h2x,ST.bezH.h2y)
        local x1p=t1*w;local x2p=t2*w;local y1p=math.clamp(y1,-.5,1.5)*h;local y2p=math.clamp(y2,-.5,1.5)*h
        local dx=x2p-x1p;local dy=y2p-y1p;local len=math.sqrt(dx*dx+dy*dy)
        new("Frame",{Size=UDim2.new(0,math.max(len,1),0,2),Position=UDim2.new(0,x1p,0,y1p),Rotation=math.deg(math.atan2(dy,dx)),AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=C.CURVE,ZIndex=84,Parent=curveCanvas})
    end
    local hs2=IS_MOBILE and 16 or 12
    for _,hd in ipairs({{"h1x","h1y",C.RED},{"h2x","h2y",C.ACC}}) do
        local hb=new("TextButton",{Text="●",Font=Enum.Font.GothamBold,TextSize=hs2,TextColor3=hd[3],BackgroundTransparency=1,Size=UDim2.new(0,hs2+4,0,hs2+4),Position=UDim2.new(ST.bezH[hd[1]],-hs2/2-2,1-ST.bezH[hd[2]],-hs2/2-2),ZIndex=86,Parent=curveCanvas})
        local dr=false
        hb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dr=true;CamLock:On();ST.isDragging=true;i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then dr=false;ST.isDragging=false;CamLock:Off() end end) end end)
        UserInputService.InputChanged:Connect(function(i) if dr and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then local cp=curveCanvas.AbsolutePosition;local cs=curveCanvas.AbsoluteSize;ST.bezH[hd[1]]=math.clamp((i.Position.X-cp.X)/cs.X,0,1);ST.bezH[hd[2]]=math.clamp(1-(i.Position.Y-cp.Y)/cs.Y,-.5,1.5);rebuildCurveEditor() end end)
    end
end

