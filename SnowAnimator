            if changed then if not ST.kfs[id] then ST.kfs[id]={} end;local kd={};for _,p in ipairs(tr.props) do pcall(function() kd[p.n]={v=tr.inst[p.n],t=p.t,es=ST.easing,ed=ST.easeDir};if ST.curveMode then kd[p.n].bh={ST.bezH.h1x,ST.bezH.h1y,ST.bezH.h2x,ST.bezH.h2y} end;last[p.n]=tr.inst[p.n] end) end;ST.kfs[id][ST.frame]=kd;dirty=true end
