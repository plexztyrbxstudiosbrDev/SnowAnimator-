graphPanel=createPanel("Graph","📊 GRAPH EDITOR",IS_MOBILE and 340 or 440,IS_MOBILE and 280 or 260)
local graphCanvas=new("Frame",{Size=UDim2.new(1,-16,1,-60),Position=UDim2.new(0,8,0,32),BackgroundColor3=Color3.fromRGB(10,15,30),ClipsDescendants=true,ZIndex=82,Parent=graphPanel});corner(graphCanvas,6);stroke(graphCanvas,C.SEP,1)
local graphInfo=lbl(graphPanel,"Select a track first",UDim2.new(1,-16,0,20),UDim2.new(0,8,1,-26),C.TX2,9);graphInfo.ZIndex=82

function rebuildGraphEditor()
    for _,c2 in pairs(graphCanvas:GetChildren()) do if c2:IsA("Frame") then c2:Destroy() end end
    local tid=ST.selTrack;if not tid or not ST.tracks[tid] then graphInfo.Text="No track selected";return end
    local tr=ST.tracks[tid];local kfs=ST.kfs[tid];if not kfs or not next(kfs) then graphInfo.Text="No keyframes";return end
    local w=graphCanvas.AbsoluteSize.X;local h=graphCanvas.AbsoluteSize.Y;if w<10 then w=380 end;if h<10 then h=180 end
    local allF={};for f in pairs(kfs) do table.insert(allF,f) end;table.sort(allF);if #allF<1 then return end
    local minF=allF[1];local maxF=allF[#allF];if maxF<=minF then maxF=minF+10 end
    graphInfo.Text=tr.name.." | "..#allF.." KF | F"..minF.."-"..maxF
    for g=0,4 do
        new("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(g/4,0,0,0),BackgroundColor3=C.SEP,BackgroundTransparency=0.7,ZIndex=83,Parent=graphCanvas})
        new("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,g/4,0),BackgroundColor3=C.SEP,BackgroundTransparency=0.7,ZIndex=83,Parent=graphCanvas})
    end
    local colors={C.CURVE,C.CURVE2,C.KF,C.RED,C.GRN,C.CYAN,C.ORANGE,C.PURPLE}
    local ci=0
    -- For Motor6D, show rotation angles
    if tr.type=="Motor6D" then
        ci=ci+1;local col=colors[1]
        local vals={}
        for _,f in ipairs(allF) do
            if kfs[f] and kfs[f]["Transform"] then
                local _,rot=cfToRot(kfs[f]["Transform"].v)
                table.insert(vals,{f=f,rx=rot.X,ry=rot.Y,rz=rot.Z})
            end
        end
        if #vals>=2 then
            for axis,aname,acol in function() local idx2=0;return function() idx2=idx2+1;if idx2==1 then return 1,"RX",C.RED elseif idx2==2 then return 2,"RY",C.GRN elseif idx2==3 then return 3,"RZ",C.ACC end end end do
                local prop=axis==1 and "rx" or axis==2 and "ry" or "rz"
                local minV,maxV=-180,180
                for i2=1,#vals-1 do
                    local x1=((vals[i2].f-minF)/(maxF-minF))*w
                    local y1=(1-(vals[i2][prop]-minV)/(maxV-minV))*h
                    local x2=((vals[i2+1].f-minF)/(maxF-minF))*w
                    local y2=(1-(vals[i2+1][prop]-minV)/(maxV-minV))*h
                    local dx2=x2-x1;local dy2=y2-y1;local len=math.sqrt(dx2*dx2+dy2*dy2)
                    new("Frame",{Size=UDim2.new(0,math.max(len,1),0,2),Position=UDim2.new(0,x1,0,y1),Rotation=math.deg(math.atan2(dy2,dx2)),AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=acol,ZIndex=84,Parent=graphCanvas})
                end
                lbl(graphCanvas,aname,UDim2.new(0,20,0,10),UDim2.new(0,2,0,axis*12),acol,7).ZIndex=85
            end
        end
    end
    -- Numeric properties
    for _,prop in ipairs(tr.props) do if prop.t~="Number" then continue end
        ci=ci+1;local col=colors[((ci-1)%#colors)+1]
        local vals={};local minV,maxV=math.huge,-math.huge
        for _,f in ipairs(allF) do if kfs[f] and kfs[f][prop.n] then local v=kfs[f][prop.n].v;if type(v)=="number" then table.insert(vals,{f=f,v=v});minV=math.min(minV,v);maxV=math.max(maxV,v) end end end
        if #vals<2 then continue end;if maxV<=minV then maxV=minV+1 end
        for i2=1,#vals-1 do
            local x1=((vals[i2].f-minF)/(maxF-minF))*w;local y1=(1-(vals[i2].v-minV)/(maxV-minV))*h
            local x2=((vals[i2+1].f-minF)/(maxF-minF))*w;local y2=(1-(vals[i2+1].v-minV)/(maxV-minV))*h
            local dx2=x2-x1;local dy2=y2-y1;local len=math.sqrt(dx2*dx2+dy2*dy2)
            new("Frame",{Size=UDim2.new(0,math.max(len,1),0,2),Position=UDim2.new(0,x1,0,y1),Rotation=math.deg(math.atan2(dy2,dx2)),AnchorPoint=Vector2.new(0,0.5),BackgroundColor3=col,ZIndex=84,Parent=graphCanvas})
        end
        for _,vd in ipairs(vals) do local px2=((vd.f-minF)/(maxF-minF))*w;local py2=(1-(vd.v-minV)/(maxV-minV))*h;local dot=new("Frame",{Size=UDim2.new(0,6,0,6),Position=UDim2.new(0,px2-3,0,py2-3),BackgroundColor3=col,ZIndex=85,Parent=graphCanvas});corner(dot,3) end
        lbl(graphCanvas,prop.n,UDim2.new(0,40,0,10),UDim2.new(0,2,0,ci*12),col,7).ZIndex=85
    end
end

