-- Math
local function bO(x) local n=7.5625;local d=2.75;if x<1/d then return n*x*x elseif x<2/d then x=x-1.5/d;return n*x*x+0.75 elseif x<2.5/d then x=x-2.25/d;return n*x*x+0.9375 else x=x-2.625/d;return n*x*x+0.984375 end end
local function eI(x,s) if s=="Linear" then return x elseif s=="Quad" then return x*x elseif s=="Cubic" then return x^3 elseif s=="Quart" then return x^4 elseif s=="Quint" then return x^5 elseif s=="Sine" then return 1-math.cos(x*math.pi/2) elseif s=="Exponential" then return x==0 and 0 or 2^(10*(x-1)) elseif s=="Circular" then return 1-math.sqrt(math.max(0,1-x*x)) elseif s=="Elastic" then if x==0 or x==1 then return x end;return -(2^(10*(x-1)))*math.sin((x-1.075)*2*math.pi/0.3) elseif s=="Back" then return x*x*((1.70158+1)*x-1.70158) elseif s=="Bounce" then return 1-bO(1-x) end;return x end
local function EE(t,s,d) if d=="In" then return eI(t,s) elseif d=="Out" then return 1-eI(1-t,s) else if t<0.5 then return eI(t*2,s)/2 else return 1-eI((1-t)*2,s)/2 end end end
local function BezEval(t,h1x,h1y,h2x,h2y) local function cb(t2,p0,p1,p2,p3) local u=1-t2;return u*u*u*p0+3*u*u*t2*p1+3*u*t2*t2*p2+t2*t2*t2*p3 end;local lo,hi=0,1;for _=1,20 do local m2=(lo+hi)/2;if cb(m2,0,h1x,h2x,1)<t then lo=m2 else hi=m2 end end;return cb((lo+hi)/2,0,h1y,h2y,1) end
local function IV(v1,v2,a,vt) if vt=="CFrame" then return v1:Lerp(v2,a) elseif vt=="Vector3" then return v1:Lerp(v2,a) elseif vt=="Color3" then return Color3.new(lerp(v1.R,v2.R,a),lerp(v1.G,v2.G,a),lerp(v1.B,v2.B,a)) elseif vt=="Number" then return lerp(v1,v2,a) elseif vt=="UDim2" then return UDim2.new(lerp(v1.X.Scale,v2.X.Scale,a),lerp(v1.X.Offset,v2.X.Offset,a),lerp(v1.Y.Scale,v2.Y.Scale,a),lerp(v1.Y.Offset,v2.Y.Offset,a)) end;return a<0.5 and v1 or v2 end
local function cfToRot(cf) local x,y,z=cf:ToEulerAnglesXYZ();return cf.Position,Vector3.new(math.deg(x),math.deg(y),math.deg(z)) end
local function rotToCF(pos,rot) return CFrame.new(pos)*CFrame.Angles(math.rad(rot.X),math.rad(rot.Y),math.rad(rot.Z)) end

