function persistSaves()
    local sd = LoadFromStorage()
    -- Convert saves to serializable format (strip instances)
    local serSaves = {}
    for _,sv in ipairs(ST.saves) do
        local serKFs = {}
        for id,kfs in pairs(sv.KFs or {}) do
            serKFs[id] = {}
            for f,kd in pairs(kfs) do
                serKFs[id][tostring(f)] = {}
                for pn,pi in pairs(kd) do
                    local vStr = ""
                    if pi.t == "CFrame" then
                        local comps = {pi.v:GetComponents()}
                        local parts = {}
                        for _,x in ipairs(comps) do table.insert(parts, string.format("%.5f",x)) end
                        vStr = table.concat(parts,",")
                    elseif pi.t == "Vector3" then
                        vStr = string.format("%.5f,%.5f,%.5f",pi.v.X,pi.v.Y,pi.v.Z)
                    elseif pi.t == "Color3" then
                        vStr = string.format("%.5f,%.5f,%.5f",pi.v.R,pi.v.G,pi.v.B)
                    elseif pi.t == "Number" then
                        vStr = tostring(pi.v)
                    elseif pi.t == "UDim2" then
                        vStr = string.format("%.5f,%d,%.5f,%d",pi.v.X.Scale,pi.v.X.Offset,pi.v.Y.Scale,pi.v.Y.Offset)
                    end
                    serKFs[id][tostring(f)][pn] = {
                        v=vStr, t=pi.t, es=pi.es or "Linear", ed=pi.ed or "InOut",
                        bh=pi.bh
                    }
                end
            end
        end
        table.insert(serSaves, {
            Name=sv.Name, Purpose=sv.Purpose, Speed=sv.Speed,
            Total=sv.Total, Loop=sv.Loop, KFs=serKFs,
            TrackNames=sv.TrackNames or {}
        })
    end
    sd.saves = serSaves
    SaveToStorage(sd)
end

