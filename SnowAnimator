    for _,c2 in pairs(tlScroll:GetChildren()) do if c2:IsA("Frame") then c2:Destroy() end end
    local px=(IS_MOBILE and 5 or 4)*ST.zoom;local tw=math.max(ST.total*px,tlPanel.AbsoluteSize.X)
    local step=math.max(1,math.floor(18/px))
    for f=0,ST.total,step do if f%(step*5)==0 then new("TextLabel",{Text=tostring(f),Font=Enum.Font.Gotham,TextSize=7,TextColor3=C.TX2,BackgroundTransparency=1,Size=UDim2.new(0,20,1,0),Position=UDim2.new(0,f*px-10-ST.scrollX,0,0),Parent=tlHeader}) end end
    local sorted={};for id,tr in pairs(ST.tracks) do table.insert(sorted,{id=id,tr=tr}) end;table.sort(sorted,function(a,b) return a.tr.name<b.tr.name end)
    local yOff=0;local rH=IS_MOBILE and 20 or 16
    for i,item in ipairs(sorted) do
        local id=item.id;local kfs=ST.kfs[id] or {}
        local row=new("Frame",{Size=UDim2.new(0,tw,0,rH),Position=UDim2.new(0,0,0,yOff),BackgroundColor3=i%2==0 and C.TRK or C.TRA,BackgroundTransparency=0.3,Parent=tlScroll})
