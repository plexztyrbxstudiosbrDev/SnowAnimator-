function pushUndo() table.insert(ST.undo,{d=deepCopy(ST.kfs)});if #ST.undo>50 then table.remove(ST.undo,1) end;ST.redo={} end
function clearGhosts() for _,g in pairs(ST.ghostParts) do pcall(function() g:Destroy() end) end;ST.ghostParts={} end

function persistSaves()
    local sd=LoadPersist();local ss={}
    for _,sv in ipairs(ST.saves) do
        local sk={};for id,kfs in pairs(sv.KFs or {}) do sk[id]={};for f,kd in pairs(kfs) do sk[id][tostring(f)]={};for pn,pi in pairs(kd) do
            local vStr="";if pi.t=="CFrame" then local c3={pi.v:GetComponents()};local p3={};for _,x in ipairs(c3) do table.insert(p3,string.format("%.5f",x)) end;vStr=table.concat(p3,",")
            elseif pi.t=="Vector3" then vStr=string.format("%.5f,%.5f,%.5f",pi.v.X,pi.v.Y,pi.v.Z)
            elseif pi.t=="Color3" then vStr=string.format("%.5f,%.5f,%.5f",pi.v.R,pi.v.G,pi.v.B)
            elseif pi.t=="Number" then vStr=tostring(pi.v)
            elseif pi.t=="UDim2" then vStr=string.format("%.5f,%d,%.5f,%d",pi.v.X.Scale,pi.v.X.Offset,pi.v.Y.Scale,pi.v.Y.Offset) end
            sk[id][tostring(f)][pn]={v=vStr,t=pi.t,es=pi.es,ed=pi.ed,bh=pi.bh}
        end end end;table.insert(ss,{Name=sv.Name,Purpose=sv.Purpose,Speed=sv.Speed,Total=sv.Total,Loop=sv.Loop,KFs=sk,TrackNames=sv.TrackNames})
    end;sd.saves=ss;SavePersist(sd)
end

function addKeyframe()
    if not ST.target then notify("🎯 Select first!",C.YEL) return end
    pushUndo();local f=ST.frame;local ct=0
    for id,tr in pairs(ST.tracks) do if tr.vis and not tr.lock then
        if not ST.kfs[id] then ST.kfs[id]={} end;local kd={}
        for _,p in ipairs(tr.props) do pcall(function() kd[p.n]={v=tr.inst[p.n],t=p.t,es=ST.easing,ed=ST.easeDir};if ST.curveMode then kd[p.n].bh={ST.bezH.h1x,ST.bezH.h1y,ST.bezH.h2x,ST.bezH.h2y} end end) end
        ST.kfs[id][f]=kd;ct=ct+1
    end end;notify("⚙️K @"..f.." ("..ct..")",C.GRN);rebuildTimeline()
end

function mirrorPose()
    if not ST.target then notify("Select first!",C.YEL) return end;pushUndo();local ct=0
    local pd={};for id,tr in pairs(ST.tracks) do if tr.type=="Motor6D" then pd[tr.name]=tr.inst.Transform end end
    for id,tr in pairs(ST.tracks) do if tr.type~="Motor6D" then continue end;local mn=MIRROR[tr.name]
        if mn and pd[mn] then local p,r=cfToRot(pd[mn]);tr.inst.Transform=rotToCF(Vector3.new(-p.X,p.Y,p.Z),Vector3.new(r.X,-r.Y,-r.Z));ct=ct+1
        elseif not mn then local p,r=cfToRot(tr.inst.Transform);tr.inst.Transform=rotToCF(Vector3.new(-p.X,p.Y,p.Z),Vector3.new(r.X,-r.Y,-r.Z));ct=ct+1 end
    end;notify("🪞 Mirrored "..ct,C.PINK)
end

function loadTarget(target)
    ST.target=target;ST.tracks={};ST.kfs={};ST.originals={}
    local function addTrack(inst,tp) local id=inst:GetFullName();if ST.tracks[id] then return end;local props=getProps(inst);if #props==0 then return end;ST.tracks[id]={inst=inst,name=inst.Name,type=tp,props=props,vis=true,lock=false};ST.kfs[id]={};ST.originals[id]={};for _,p in ipairs(props) do pcall(function() ST.originals[id][p.n]=inst[p.n] end) end end
    if target:IsA("Model") then for _,d in pairs(target:GetDescendants()) do if d:IsA("Motor6D") then addTrack(d,"Motor6D") end end;for _,d in pairs(target:GetDescendants()) do if d:IsA("BasePart") then addTrack(d,"BasePart") end end
    elseif target:IsA("BasePart") then addTrack(target,"BasePart");local mdl=target:FindFirstAncestorOfClass("Model");if mdl and mdl~=Workspace then for _,d in pairs(mdl:GetDescendants()) do if d:IsA("Motor6D") then addTrack(d,"Motor6D") elseif d:IsA("BasePart") then addTrack(d,"BasePart") end end end
    elseif target:IsA("GuiObject") then addTrack(target,"GuiObject");for _,d in pairs(target:GetDescendants()) do if d:IsA("GuiObject") then addTrack(d,"GuiObject") end end
    else for _,d in pairs(target:GetDescendants()) do if d:IsA("Motor6D") then addTrack(d,"Motor6D") elseif d:IsA("BasePart") then addTrack(d,"BasePart") elseif d:IsA("GuiObject") then addTrack(d,"GuiObject") end end end
    local ct=0;for _ in pairs(ST.tracks) do ct=ct+1 end;notify("✅ "..target.Name.." ("..ct.." tracks)",C.GRN,3)
    pcall(function() game:GetService("Selection"):Set({target}) end);rebuildTracks();rebuildTimeline();startGizmoMonitor()
end

