function exportViaID()
    if not ST.target then notify("No target!",C.YEL);return nil end
    local hasData=false;for _,kfs in pairs(ST.kfs) do if next(kfs) then hasData=true;break end end
    if not hasData then notify("No keyframes!",C.YEL);return nil end

    local aid="SNA_"..genID()
    local root=ReplicatedStorage:FindFirstChild("SnowAnimatorData")
    if not root then root=Instance.new("Folder");root.Name="SnowAnimatorData";root.Parent=ReplicatedStorage end

    local af=Instance.new("Folder");af.Name=aid;af.Parent=root
    local function sv(n,c2,v,p) local i=Instance.new(c2);i.Name=n;i.Value=v;i.Parent=p end
    sv("Speed","NumberValue",ST.speed,af);sv("Total","IntValue",ST.total,af);sv("Loop","BoolValue",ST.exportLoop,af)

    local tf=Instance.new("Folder");tf.Name="Tracks";tf.Parent=af
    for id,tr in pairs(ST.tracks) do
        local kfs=ST.kfs[id];if not kfs or not next(kfs) then continue end
        local trf=Instance.new("Folder");trf.Name=tr.name;trf.Parent=tf
        sv("Type","StringValue",tr.type,trf)
        local ov=Instance.new("ObjectValue");ov.Name="Ref";ov.Value=tr.inst;ov.Parent=trf
        local frames2={};for f in pairs(kfs) do table.insert(frames2,f) end;table.sort(frames2)
        for _,f in ipairs(frames2) do
            local ff=Instance.new("Folder");ff.Name=tostring(f);ff.Parent=trf
            for pn,pi in pairs(kfs[f]) do
                local pf3=Instance.new("Folder");pf3.Name=pn;pf3.Parent=ff
                sv("T","StringValue",pi.t,pf3);sv("ES","StringValue",pi.es or "Linear",pf3);sv("ED","StringValue",pi.ed or "InOut",pf3)
                if pi.bh then sv("BH","StringValue",string.format("%.4f,%.4f,%.4f,%.4f",pi.bh[1],pi.bh[2],pi.bh[3],pi.bh[4]),pf3) end
                if pi.t=="CFrame" then local c3={pi.v:GetComponents()};local p3={};for _,x in ipairs(c3) do table.insert(p3,string.format("%.5f",x)) end;sv("V","StringValue",table.concat(p3,","),pf3)
                elseif pi.t=="Vector3" then sv("V","StringValue",string.format("%.5f,%.5f,%.5f",pi.v.X,pi.v.Y,pi.v.Z),pf3)
                elseif pi.t=="Color3" then sv("V","StringValue",string.format("%.5f,%.5f,%.5f",pi.v.R,pi.v.G,pi.v.B),pf3)
                elseif pi.t=="Number" then sv("V","NumberValue",pi.v,pf3)
                elseif pi.t=="UDim2" then sv("V","StringValue",string.format("%.5f,%d,%.5f,%d",pi.v.X.Scale,pi.v.X.Offset,pi.v.Y.Scale,pi.v.Y.Offset),pf3) end
            end
        end
    end

    -- Create auto player script in ReplicatedStorage
    local existingPlayer = root:FindFirstChild("SNA_AutoPlayer")
    if not existingPlayer then
        local playerScript = Instance.new("Script")
        playerScript.Name = "SNA_AutoPlayer"
        playerScript.Source = generateFullScript() or "-- No data"
        playerScript.Parent = root
    end

    notify("✅ ID: "..aid,C.GRN,4)
    notify("Data saved in ReplicatedStorage!",C.ICE,5)

    -- Also generate and show the script
    local code = generateFullScript()
    if code then
        toClip(code)
        svBox.Text = code
        scriptViewPanel.Visible = true
        notify("📋 Script also copied!",C.GRN,3)
    end

    return aid
end

