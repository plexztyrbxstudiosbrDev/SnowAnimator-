local function SaveData(data)
    local json = HttpService:JSONEncode(data)
    pcall(function() if writefile then writefile("SNA_v9.json",json) end end)
    pcall(function()
        local sv = ReplicatedStorage:FindFirstChild("SNA_Persist")
        if not sv then sv=Instance.new("StringValue");sv.Name="SNA_Persist";sv.Parent=ReplicatedStorage end
        sv.Value=json
    end)
end

local function LoadData()
    local d
    pcall(function() if readfile and isfile and isfile("SNA_v9.json") then d=HttpService:JSONDecode(readfile("SNA_v9.json")) end end)
    if d then return d end
    pcall(function() local sv=ReplicatedStorage:FindFirstChild("SNA_Persist");if sv and sv.Value~="" then d=HttpService:JSONDecode(sv.Value) end end)
    return d or {saves={},slots={}}
end

