function mirrorPose()
    if not ST.target then notify("Select first!",C.YEL) return end
    pushUndo();local ct=0
    local poseData={}
    -- Collect current transforms by name
    for id,tr in pairs(ST.tracks) do
        if tr.type=="Motor6D" then poseData[tr.name]=tr.inst.Transform end
    end
    -- Apply mirrored
    for id,tr in pairs(ST.tracks) do
        if tr.type~="Motor6D" then continue end
        local mirrorName=MIRROR_MAP[tr.name]
        if mirrorName and poseData[mirrorName] then
            tr.inst.Transform=mirrorCFrame(poseData[mirrorName]);ct=ct+1
        elseif tr.name=="Neck" or tr.name=="RootJoint" or tr.name=="Root" or tr.name=="Waist" then
            tr.inst.Transform=mirrorCFrame(poseData[tr.name] or tr.inst.Transform);ct=ct+1
        end
    end
    notify("🪞 Mirrored "..ct.." joints",C.PINK);showProps(ST.selTrack)
end

function savePose(name)
