        local kfs=ST.kfs[id];if not kfs or not tr.inst or not tr.inst.Parent then continue end
        local frames={};for f in pairs(kfs) do table.insert(frames,f) end;table.sort(frames);if #frames==0 then continue end
        local pf,nf,pd,nd;for _,f in ipairs(frames) do if f<=frame then pf=f;pd=kfs[f] end;if f>frame and not nf then nf=f;nd=kfs[f] end end
        if pf==frame and pd then for pn,pi in pairs(pd) do pcall(function() tr.inst[pn]=pi.v end) end
        elseif pf and nf and pd and nd then local t=(frame-pf)/(nf-pf);for pn,pi in pairs(pd) do if nd[pn] then local a;if pi.bh then a=BezEval(t,pi.bh[1],pi.bh[2],pi.bh[3],pi.bh[4]) else a=EE(t,pi.es or "Linear",pi.ed or "InOut") end;pcall(function() tr.inst[pn]=IV(pi.v,nd[pn].v,a,pi.t) end) end end
