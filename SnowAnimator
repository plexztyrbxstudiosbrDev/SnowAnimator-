--////////////////////////////////////
-- THE PERFECT EXPORT FUNCTION
-- Generates ONE complete self-contained script
--////////////////////////////////////
function generateFullScript()
    -- Check if there's data
    local hasData = false
    for id,kfs in pairs(ST.kfs) do if next(kfs) then hasData=true;break end end
    if not hasData then return nil end

    local L = {} -- lines
    local function W(s) table.insert(L, s) end

    W("-- ❄️ SNOW ANIMATOR v10 - Animation Script")
    W("-- Generated automatically. Just paste anywhere!")
    W("-- 🇧🇷: Cole em Script ou LocalScript onde quiser")
    W("-- 🇺🇸: Paste in any Script or LocalScript")
    W("--")
    W("-- WHERE TO PASTE / ONDE COLAR:")
    W("-- 🤖 NPC: Script INSIDE the Model")
    W("-- 🎮 Player: Script in StarterCharacterScripts")
    W("-- 🖼️ UI: LocalScript in StarterGui")
    W("-- ⚔️ Tool: Script INSIDE the Tool")
    W("--")
    W("-- The script searches by NAME inside script.Parent")
    W("-- O script busca pelo NOME dentro de script.Parent")
    W("")
    W("local RS = game:GetService('RunService')")
    W("local root = script.Parent")
    W("task.wait(0.5)")
    W("")

    -- Animation data
    W("local SPD = " .. ST.speed)
    W("local FPS = 60")
    W("local TOTAL = " .. ST.total)
    W("local LOOP = " .. (ST.exportLoop and "true" or "false"))
    W("")

    -- Easing engine (compact)
    W("local function bO(x) local n,d=7.5625,2.75;if x<1/d then return n*x*x elseif x<2/d then x=x-1.5/d;return n*x*x+.75 elseif x<2.5/d then x=x-2.25/d;return n*x*x+.9375 else x=x-2.625/d;return n*x*x+.984375 end end")
    W("local function eI(x,s) if s=='Linear' then return x elseif s=='Quad' then return x*x elseif s=='Cubic' then return x^3 elseif s=='Quart' then return x^4 elseif s=='Quint' then return x^5 elseif s=='Sine' then return 1-math.cos(x*math.pi/2) elseif s=='Exponential' then return x==0 and 0 or 2^(10*(x-1)) elseif s=='Circular' then return 1-math.sqrt(math.max(0,1-x*x)) elseif s=='Elastic' then if x==0 or x==1 then return x end;return -(2^(10*(x-1)))*math.sin((x-1.075)*2*math.pi/.3) elseif s=='Back' then return x*x*(2.70158*x-1.70158) elseif s=='Bounce' then return 1-bO(1-x) end;return x end")
    W("local function EE(t,s,d) if d=='In' then return eI(t,s) elseif d=='Out' then return 1-eI(1-t,s) else if t<.5 then return eI(t*2,s)/2 else return 1-eI((1-t)*2,s)/2 end end end")
    W("local function BZ(t,a,b,c,d) local function cb(t2,p0,p1,p2,p3) local u=1-t2;return u*u*u*p0+3*u*u*t2*p1+3*u*t2*t2*p2+t2*t2*t2*p3 end;local lo,hi=0,1;for _=1,20 do local m=(lo+hi)/2;if cb(m,0,a,c,1)<t then lo=m else hi=m end end;return cb((lo+hi)/2,0,b,d,1) end")
    W("local function LR(a,b,t) return a+(b-a)*t end")
    W("local function IV(a,b,t,tp) if tp=='CFrame' then return a:Lerp(b,t) elseif tp=='Vector3' then return a:Lerp(b,t) elseif tp=='Color3' then return Color3.new(LR(a.R,b.R,t),LR(a.G,b.G,t),LR(a.B,b.B,t)) elseif tp=='Number' then return LR(a,b,t) elseif tp=='UDim2' then return UDim2.new(LR(a.X.Scale,b.X.Scale,t),LR(a.X.Offset,b.X.Offset,t),LR(a.Y.Scale,b.Y.Scale,t),LR(a.Y.Offset,b.Y.Offset,t)) end;return t<.5 and a or b end")
    W("")

    -- Track data
    W("local T = {}")
    for id, tr in pairs(ST.tracks) do
        local kfs = ST.kfs[id]
        if not kfs or not next(kfs) then continue end

        local frames = {}
        for f in pairs(kfs) do table.insert(frames, f) end
        table.sort(frames)

        -- Find the instance
        W("do")
        W("  local inst")
        W("  for _,d in pairs(root:GetDescendants()) do")
        if tr.type == "Motor6D" then
            W("    if d:IsA('Motor6D') and d.Name == '" .. tr.name:gsub("'","\\'") .. "' then inst = d; break end")
        elseif tr.type == "BasePart" then
            W("    if d:IsA('BasePart') and d.Name == '" .. tr.name:gsub("'","\\'") .. "' then inst = d; break end")
        elseif tr.type == "GuiObject" then
            W("    if d:IsA('GuiObject') and d.Name == '" .. tr.name:gsub("'","\\'") .. "' then inst = d; break end")
        end
        W("  end")
        W("  if inst then")
        W("    local kf = {}")

        for _, f in ipairs(frames) do
            W("    kf[" .. f .. "] = {")
            for pn, pi in pairs(kfs[f]) do
                local vStr
                if pi.t == "CFrame" then
                    local comps = {pi.v:GetComponents()}
                    local parts = {}
                    for _, x in ipairs(comps) do table.insert(parts, string.format("%.4f", x)) end
                    vStr = "CFrame.new(" .. table.concat(parts, ",") .. ")"
                elseif pi.t == "Vector3" then
                    vStr = string.format("Vector3.new(%.4f,%.4f,%.4f)", pi.v.X, pi.v.Y, pi.v.Z)
                elseif pi.t == "Color3" then
                    vStr = string.format("Color3.new(%.4f,%.4f,%.4f)", pi.v.R, pi.v.G, pi.v.B)
                elseif pi.t == "Number" then
                    vStr = string.format("%.4f", pi.v)
                elseif pi.t == "UDim2" then
                    vStr = string.format("UDim2.new(%.4f,%d,%.4f,%d)", pi.v.X.Scale, pi.v.X.Offset, pi.v.Y.Scale, pi.v.Y.Offset)
                end
                if vStr then
                    local bhStr = "nil"
                    if pi.bh then bhStr = string.format("{%.3f,%.3f,%.3f,%.3f}", pi.bh[1], pi.bh[2], pi.bh[3], pi.bh[4]) end
                    W("      ['" .. pn .. "']={v=" .. vStr .. ",t='" .. pi.t .. "',es='" .. (pi.es or "Linear") .. "',ed='" .. (pi.ed or "InOut") .. "',bh=" .. bhStr .. "},")
                end
            end
            W("    }")
        end

        W("    table.insert(T, {i=inst, kf=kf})")
        W("  else")
        W("    warn('❄️ SNA: " .. tr.name .. " not found')")
        W("  end")
        W("end")
    end

    W("")
    W("-- Play")
    W("if #T == 0 then warn('❄️ SNA: No tracks found!') return end")
    W("local cf, acc = 0, 0")
    W("RS.Heartbeat:Connect(function(dt)")
    W("  acc = acc + dt * SPD")
    W("  while acc >= 1/FPS do")
    W("    acc = acc - 1/FPS")
    W("    cf = cf + 1")
    W("    if cf > TOTAL then if LOOP then cf = 0 else return end end")
    W("  end")
    W("  for _, t in pairs(T) do")
    W("    if not t.i or not t.i.Parent then continue end")
    W("    local fs = {}; for f in pairs(t.kf) do table.insert(fs, f) end; table.sort(fs)")
    W("    if #fs == 0 then continue end")
    W("    local pf, nf, pd, nd")
    W("    for _, f in ipairs(fs) do if f <= cf then pf=f; pd=t.kf[f] end; if f > cf and not nf then nf=f; nd=t.kf[f] end end")
    W("    if pf and nf and pd and nd then")
    W("      local tt = (cf-pf)/(nf-pf)")
    W("      for pn, pi in pairs(pd) do")
    W("        if nd[pn] then")
    W("          local a = pi.bh and BZ(tt,pi.bh[1],pi.bh[2],pi.bh[3],pi.bh[4]) or EE(tt,pi.es,pi.ed)")
    W("          pcall(function() t.i[pn] = IV(pi.v, nd[pn].v, a, pi.t) end)")
    W("        end")
    W("      end")
    W("    elseif pf and pd then")
    W("      for pn, pi in pairs(pd) do pcall(function() t.i[pn] = pi.v end) end")
    W("    end")
    W("  end")
    W("end)")
    W("print('❄️ SNA: Animation playing!')")

    return table.concat(L, "\n")
end

