        local ok,clone=pcall(function() return ST.target:Clone() end);if not ok or not clone then continue end
        clone.Name="SNA_Ghost";for _,part in pairs(clone:GetDescendants()) do
            if part:IsA("BasePart") then part.Transparency=1-ST.onionOpacity*(1-math.abs(offset)/ST.onionCount);part.CanCollide=false;part.Anchored=true;part.Color=offset<0 and Color3.fromRGB(80,80,200) or Color3.fromRGB(200,80,80)
            elseif part:IsA("Script") or part:IsA("LocalScript") or part:IsA("Sound") then part:Destroy() end
