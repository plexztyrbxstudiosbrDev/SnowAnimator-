local CamLock = {active=false}
function CamLock:On()
    if self.active then return end
    self.active = true
    pcall(function()
        ContextActionService:BindActionAtPriority("SNA_Cam",function()
            return Enum.ContextActionResult.Sink
        end,false,3000,
        Enum.UserInputType.MouseMovement,Enum.UserInputType.MouseButton2,
        Enum.UserInputType.MouseButton3,Enum.UserInputType.MouseWheel,
        Enum.UserInputType.Touch)
    end)
end
function CamLock:Off()
    if not self.active then return end
    self.active = false
    pcall(function() ContextActionService:UnbindAction("SNA_Cam") end)
end

