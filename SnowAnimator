    task.spawn(function() while SG.Parent do if ST.autoKey and not ST.playing and ST.target then
        local dirty=false;for id,tr in pairs(ST.tracks) do if not tr.vis or tr.lock then continue end;local last=lastSnap[id];if not last then continue end
